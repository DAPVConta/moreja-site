# ──────────────────────────────────────────────────────────────
# Portal Morejá — configuração de ambiente (Next.js)
# Copie para .env.local e preencha os valores reais.
# ──────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Conexão direta ao Postgres (usada por scripts em /scripts) ─────────────
SUPABASE_DB_HOST=db.xxxxxxxxxxxxx.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# ── SupremoCRM (fonte dos imóveis) ─────────────────────────────────────────
SUPREMO_JWT=
SUPREMO_API_URL=https://api.supremocrm.com.br
SUPREMO_SIT_ID=

# ── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://moreja.com.br

# ── Empresa ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PHONE=(11) 0000-0000
NEXT_PUBLIC_EMAIL=contato@moreja.com.br
NEXT_PUBLIC_ADDRESS=
NEXT_PUBLIC_WHATSAPP=55119XXXXXXXX

# ── Redes sociais ───────────────────────────────────────────────────────────
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_YOUTUBE_URL=

# ── Analytics / SEO ─────────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
NEXT_PUBLIC_LINKEDIN_CONVERSION_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
