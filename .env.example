# ──────────────────────────────────────────────────────────────
# Portal Morejá — configuração de ambiente (Next.js)
# Copie para .env.local e preencha os valores reais.
# ──────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Conexão direta ao Postgres (usada por scripts em /scripts) ─────────────
SUPABASE_DB_HOST=db.xxxxxxxxxxxxx.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# ── SupremoCRM (fonte dos imóveis) ─────────────────────────────────────────
SUPREMO_JWT=
SUPREMO_API_URL=https://api.supremocrm.com.br
SUPREMO_SIT_ID=

# ── ClaivorCRM (importação de imóveis/empreendimentos via /api/import-feed) ─
# URL completa do feed JSON, incluindo o token de acesso.
CLAIVOR_FEED_URL=https://claivorcrm.com.br/api/feeds/<conta>/json?token=<token>
# Segredo exigido no header Authorization: Bearer <FEED_IMPORT_SECRET> para
# disparar a importação. O Vercel Cron usa CRON_SECRET (aceito também).
FEED_IMPORT_SECRET=
# Fonte dos imóveis do site. Default (vazio) = 'local': serve exclusivamente
# o feed Claivor importado em properties_cache. 'supremo' reativa o
# supremo-proxy como fonte primária (comportamento antigo).
PROPERTIES_SOURCE=

# ── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://moreja.com.br
# Simulador de financiamento — app externo. Default no código
# (src/lib/simulator.ts); o caminho interno /simulacao-financiamento agora
# só redireciona para esta URL (links antigos continuam funcionando).
NEXT_PUBLIC_SIMULATOR_URL=https://simulacao.srv1577302.hstgr.cloud/simulacao-financiamento

# ── Empresa ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PHONE=+55 81 98593-1081
NEXT_PUBLIC_EMAIL=administracao@morejaimobiliaria.com.br
NEXT_PUBLIC_ADDRESS=Av. Engenheiro Domingos Ferreira 1920, sala 102, Recife/PE
NEXT_PUBLIC_WHATSAPP=5581985931081

# ── Redes sociais ───────────────────────────────────────────────────────────
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_YOUTUBE_URL=

# ── Analytics / SEO ─────────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
NEXT_PUBLIC_LINKEDIN_CONVERSION_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
